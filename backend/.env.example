# Copy this file to `.env` in the same folder and fill in your own values.
# Never commit the real `.env` file.

ENV=development
# Set to "production" on your live deployment (e.g. Render) to disable the
# public /docs, /redoc, and /openapi.json endpoints and enable the HSTS header.

# Get a free key from Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Optional: only needed if you route Gemini calls through Vertex AI on GCP
GCP_PROJECT_ID=
GCP_REGION=us-central1
USE_VERTEX_AI=false

# Comma-separated list of frontend origins allowed to call this API
# Example for this project's live deployment:
# ALLOWED_ORIGINS=https://smart-stadium-9u4n5kj8d-syedbasha27s-projects.vercel.app,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
